{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "build/",
    "module": "node16",
    "target": "es2022",
    "moduleResolution": "node16",
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "alwaysStrict": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "allowJs": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
  },
  "include": ["./**/*.ts"]
}
