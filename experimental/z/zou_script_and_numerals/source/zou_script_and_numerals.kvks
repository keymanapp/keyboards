      <key vkey="K_QUOTE">"</key>
      <key vkey="K_oE2">|</key>
      <key vkey="K_Z">¯ÇÖ</key>
      <key vkey="K_X">¯Çù</key>
      <key vkey="K_C">¯Çé</key>
      <key vkey="K_V">¯Çò</key>
      <key vkey="K_B">¯Çü</key>
      <key vkey="K_N">¯Çı</key>
      <key vkey="K_M">¯Çî</key>
      <key vkey="K_COMMA">&lt;</key>
      <key vkey="K_PERIOD">&gt;</key>
      <key vkey="K_SLASH">?</key>
    </layer>
  </encoding>
</visualkeyboard>
