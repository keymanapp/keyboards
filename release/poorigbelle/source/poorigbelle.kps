    </File>
    <File>
      <Name>..\LICENSE.md</Name>
      <Description></Description>
      <CopyLocation>0</CopyLocation>
      <FileType>.md</FileType>
    </File>
    <File>
      <Name>NotoSans-Regular.ttf</Name>
      <Description>Font Noto Sans Regular</Description>
