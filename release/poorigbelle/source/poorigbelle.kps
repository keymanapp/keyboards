      </Item>
    </Items>
  </StartMenu>
  <Info>
    <Name URL="">poorigbelle</Name>
    <Copyright URL="">pojorigkoro@yahoo.fr</Copyright>
    <Author URL="mailto:pojorigkoro@yahoo.fr">pojor</Author>
    <Description URL="">this is a fur/poorigbellé language we use to speek from darfur
i'm developing this language to use it in any phone and pc</Description>
    <Version URL=""></Version>
    <WebSite URL="https://keyman.com/keyboard/poorigbelle">https://keyman.com/keyboard/poorigbelle</WebSite>
  </Info>
  <Files>
    <File>
