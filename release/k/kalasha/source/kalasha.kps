  <Info>
    <Name URL="">Kalasha</Name>
    <Copyright URL="">© Malachi James and Elsa Cooper</Copyright>
    <Author URL="">Malachi James and Elsa Cooper</Author>
    <Description URL="">The Kaḷaṣamondr keyboard is created to type the kalasha language with Roman (Latin) script. Allowing keyboard users to write in English and Kalasha without switching keyboards.</Description>
    <Version URL=""></Version>
  </Info>
