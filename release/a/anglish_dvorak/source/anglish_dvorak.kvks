<?xml version="1.0" encoding="utf-8"?>
<visualkeyboard>
  <header>
    <version>10.0</version>
    <kbdname>anglish_dvorak</kbdname>
    <flags>
      <key102/>
    </flags>
  </header>
  <encoding name="unicode" fontname="Junicode" fontsize="12">
    <layer shift="S">
      <key vkey="K_oE2">:</key>
      <key vkey="K_1">!</key>
      <key vkey="K_QUOTE">_</key>
