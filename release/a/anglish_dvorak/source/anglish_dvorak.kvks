      <key vkey="K_Q">"</key>
      <key vkey="K_R">P</key>
      <key vkey="K_S">O</key>
      <key vkey="K_T">Y</key>
      <key vkey="K_U">Ȝ</key>
      <key vkey="K_V">Æ</key>
      <key vkey="K_W">&lt;</key>
      <key vkey="K_X">Ð</key>
      <key vkey="K_Y">F</key>
      <key vkey="K_Z">̅</key>
      <key vkey="K_6">^</key>
      <key vkey="K_HYPHEN">{</key>
      <key vkey="K_LBRKT">?</key>
      <key vkey="K_BKSLASH">|</key>
      <key vkey="K_RBRKT">+</key>
      <key vkey="K_BKQUOTE">~</key>
    </layer>
    <layer shift="">
      <key vkey="K_oE2">;</key>
      <key vkey="K_QUOTE">-</key>
      <key vkey="K_COMMA">ƿ</key>
      <key vkey="K_HYPHEN">[</key>
      <key vkey="K_PERIOD">ꝥ</key>
      <key vkey="K_SLASH">⁊</key>
      <key vkey="K_0">0</key>
      <key vkey="K_1">1</key>
      <key vkey="K_2">2</key>
      <key vkey="K_3">3</key>
      <key vkey="K_4">4</key>
