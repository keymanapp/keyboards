c thai_kedmanee generated from template at 2026-03-13 16:10:36
c with name "Thai Kedmanee"
store(&VERSION) '17.0'
store(&NAME) 'Thai Kedmanee'
store(&COPYRIGHT) 'Copyright © Samuel A. Mattix'
store(&KEYBOARDVERSION) '2.0'
store(&TARGETS) 'any'
store(&BITMAP) 'thai_kedmanee_mattix.ico'
store(&VISUALKEYBOARD) 'thai_kedmanee_mattix.kvks'
store(&LAYOUTFILE) 'thai_kedmanee_mattix.keyman-touch-layout'
store(&HOTKEY) [CTRL SHIFT K_T]

begin Unicode > use(main)

