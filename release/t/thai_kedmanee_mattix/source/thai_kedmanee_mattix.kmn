c =========================================================
c Thai special character shortcuts
c =========================================================
c Paiyanyai — OO → ฯลฯ
'ฯ' + [SHIFT K_O] > 'ฯลฯ'

c Yamakkan — `3 → ๎
'_' + [K_3] > U+0E4E

c Fongman — `" → ๏
'_' + [SHIFT K_QUOTE] > U+0E4F

c Angkhankhu — `ฯ → ๚
'_' + [SHIFT K_O] > U+0E5A dk(compose)

c Khomut — `ฯฯ → ๛
U+0E5A dk(compose) + [SHIFT K_O] > U+0E5B

c Bullet — `๑ → •
'_' + [SHIFT K_2] > U+2022

c Zero width space — `Space → ZWSP
'_' + [K_SPACE] > U+200B
